# MiMo API（OpenAI 兼容）
MIMO_BASE_URL=https://api.xiaomimimo.com/v1
MIMO_API_KEY=your_api_key_here

# Phase 1.5 Run Store
# 云端部署时请指向持久化磁盘目录，例如 /data/run_store.sqlite3
RUN_STORE_PATH=data/run_store.sqlite3

# Phase 2 Source Layer
SOURCE_STORE_PATH=data/source_store.sqlite3
JINA_READER_BASE_URL=https://r.jina.ai/http://
NEWS_API_KEY=
GITHUB_TOKEN=
CRUNCHBASE_API_KEY=
PATENT_API_KEY=

# 服务端口
# 本地可忽略；多数云平台会自动注入 PORT
PORT=8000

# 模型分配（可选，默认如下）
COLLECTOR_MODEL=mimo-v2.5
ANALYZER_MODEL=mimo-v2.5
WRITER_MODEL=mimo-v2.5
VERIFIER_MODEL=mimo-v2.5-pro

# 仅前端独立开发时需要；同服务部署保持为空即可
# VITE_API_BASE_URL=http://127.0.0.1:8000
